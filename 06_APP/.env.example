# .env — variáveis de ambiente do app (NÃO versionar; este .example é o modelo).
# O app cria/preenche o .env automaticamente na 1ª execução com valores padrão.
# Edite manualmente apenas para trocar credenciais.

# Chave de sessão do Flask — gerada automaticamente se ausente.
FLASK_SECRET_KEY=gerado-automaticamente-na-primeira-execucao

# ── Autenticação (STORY-01-06) ──────────────────────────────────────────────
# Usuário único do sistema. Default de fábrica: luana
APP_USUARIO=luana

# Senha guardada como HASH (nunca em texto plano). Default de fábrica: matine2026
# Para trocar a senha, gere um novo hash e cole abaixo:
#   python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('suasenha', method='pbkdf2:sha256'))"
APP_SENHA=cole-o-hash-gerado-aqui
